// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Пользователь
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  role      String    @default("user")
  createdAt DateTime  @default(now())
  orders    Order[]
  cartItems CartItem[]   // ← добавлено
}

// Товар – теперь первичный ключ article (уникальный артикул)
model Product {
  article        String      @id
  name           String
  description    String
  price          Int
  oldPrice       Int?
  images         String
  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id])
  gameSystem     String
  scale          String
  type           String
  faction        String?
  fileFormat     String
  tags           String
  inStock        Boolean     @default(true)
  downloadsCount Int         @default(0)
  fileUrl        String?
  createdAt      DateTime    @default(now())
  featured       Boolean     @default(false)
  popularity     Int         @default(0)
  orderItems     OrderItem[]
  cartItems      CartItem[]   // ← добавлено
}

// Категория
model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  parentId String?
  parent   Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]
}

// Заказ
model Order {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  total          Int
  status         String      @default("pending") // pending, processing, shipped, delivered, cancelled
  address        String      // адрес доставки
  phone          String?     // телефон для связи
  comment        String?     // комментарий к заказу
  deliveryMethod String?     // способ доставки (например, "СДЭК", "Почта России")
  paymentMethod  String?     // способ оплаты (пока демо)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
}

// Товары в заказе
model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  productArticle String
  product        Product  @relation(fields: [productArticle], references: [article])
  quantity       Int
  priceAtPurchase Int
}

// Токены для скачивания
model DownloadToken {
  id             String   @id @default(cuid())
  token          String   @unique
  orderId        String
  productArticle String
  expiresAt      DateTime
  used           Boolean  @default(false)
}

// Корзина (новая модель)
model CartItem {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productArticle String
  product        Product  @relation(fields: [productArticle], references: [article])
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}