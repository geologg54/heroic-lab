// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  password         String
  role             String    @default("user")
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  orders           Order[]
  cartItems        CartItem[]
  supportMessages  SupportMessage[]  // ← добавлено
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  filter1Name String?
  filter2Name String?
  filter3Name String?
  filter4Name String?
  filter5Name String?
}

model Product {
  article     String   @id
  name        String
  searchName  String
  price       Int
  oldPrice    Int?
  description String   @default("")
  images      String   @default("")
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  filter1     String?
  filter2     String?
  filter3     String?
  filter4     String?
  filter5     String?

  stock       Int      @default(0)
  heightMax   Float?
  baseMax     Float?
  heightMin   Float?
  baseMin     Float?
  assembly    String?
  contents    String?
  artist      String?

  scale       String   @default("32mm")
  tags        String   @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]
  @@index([searchName])
}

model CartItem {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  productArticle String
  product        Product  @relation(fields: [productArticle], references: [article])
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id             String    @id @default(cuid())
  orderNumber    Int       @unique
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  guestEmail     String?
  guestName      String?
  total          Int
  discount       Int       @default(0)
  address        String
  phone          String?
  comment        String?
  deliveryMethod String?
  paymentMethod  String?
  status         String    @default("processing")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  couponId       String?
  coupon         Coupon?   @relation(fields: [couponId], references: [id])
  items          OrderItem[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  productArticle  String
  product         Product  @relation(fields: [productArticle], references: [article])
  quantity        Int
  priceAtPurchase Int
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  type            String
  value           Int
  minOrderAmount  Int?
  maxUses         Int?
  usedCount       Int      @default(0)
  validFrom       DateTime @default(now())
  validUntil      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders          Order[]
}

// Новая система обращений
model SupportConversation {
  id               String           @id @default(cuid())
  ticketNumber     String           @unique
  customerEmail    String
  customerName     String?
  subject          String?
  status           String           @default("open")
  adminLastReadAt  DateTime?        // ← добавили только это
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  messages         SupportMessage[]
}

model SupportMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     String             // "customer" или "admin"
  adminId        String?            // ID администратора, если senderType = "admin"
  admin          User?              @relation(fields: [adminId], references: [id])
  message        String
  createdAt      DateTime           @default(now())
}

model Material {
  id              String   @id @default(cuid())
  name            String
  description     String?
  priceMultiplier Float    @default(1.0)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}